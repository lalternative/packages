{
  "name": "@lalternative/skalpai-sdk-react",
  "version": "0.1.1",
  "description": "React wrapper for the Skalpai feedback widget",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@lalternative/skalpai-feedback-widget": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "skalpai",
    "feedback",
    "react",
    "widget"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lalternative/packages.git",
    "directory": "skalpai/sdk-react"
  }
}
